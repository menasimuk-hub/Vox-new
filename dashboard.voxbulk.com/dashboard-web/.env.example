# VITE_API_BASE_URL=

VITE_PUBLIC_SIGNIN_URL=http://localhost:5173/signin
VITE_PUBLIC_APP_URL=http://localhost:5173

VITE_PROXY_API_TARGET=http://127.0.0.1:8000

