# Production API (FastAPI). Used by `npm run build` / `npm run preview`.
VITE_API_BASE_URL=https://api.voxbulk.com
VITE_POST_LOGIN_ADMIN_URL=https://admin.voxbulk.com
VITE_POST_LOGIN_DASHBOARD_URL=https://dashboard.voxbulk.com

# Local dev: run `npm run dev` (NOT build). Uses .env.development → http://127.0.0.1:8000
# Start API first: cd voxbulk-api && python -m uvicorn main:app --host 127.0.0.1 --port 8000
# Open: http://localhost:5173