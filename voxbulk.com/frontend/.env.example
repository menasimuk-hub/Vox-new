# Production API (FastAPI). Used by `npm run build` / `npm run preview`.
VITE_API_BASE_URL=https://api.voxbulk.com
VITE_POST_LOGIN_ADMIN_URL=https://admin.voxbulk.com
VITE_POST_LOGIN_DASHBOARD_URL=https://dashboard.voxbulk.com

# Local dev: copy to .env.development.local (gitignored), leave VITE_API_BASE_URL empty for Vite proxy.
# VITE_API_BASE_URL=
# VITE_POST_LOGIN_ADMIN_URL=http://127.0.0.1:5174
# VITE_POST_LOGIN_DASHBOARD_URL=http://127.0.0.1:5175