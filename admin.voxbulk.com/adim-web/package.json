{
  "name": "voxbulk-admin-hifi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync:brand": "node ../../scripts/sync-brand-assets.mjs",
    "sync:build-info": "node ../../scripts/write-admin-build-info.mjs",
    "predev": "npm run sync:brand && npm run sync:build-info",
    "prebuild": "npm run sync:brand && npm run sync:build-info",
    "dev": "vite",
    "dev:api": "node ../../scripts/dev-api.mjs",
    "dev:full": "concurrently -k -n api,admin -c blue,magenta \"npm run dev:api\" \"wait-on -t 120000 http-get://127.0.0.1:8000/health && vite\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vapi-ai/web": "^2.5.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  }
}
