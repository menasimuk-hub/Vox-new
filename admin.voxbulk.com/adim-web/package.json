{
  "name": "voxbulk-admin-hifi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync:brand": "node ../../scripts/sync-brand-assets.mjs",
    "sync:build-info": "node ../../scripts/write-admin-build-info.mjs",
    "predev": "npm run sync:brand && npm run sync:build-info",
    "prebuild": "npm run sync:brand && npm run sync:build-info",
    "dev": "vite",
    "dev:api": "node ../../scripts/dev-api.mjs",
    "dev:full": "concurrently -k -n api,admin -c blue,magenta \"npm run dev:api\" \"wait-on -t 120000 http-get://127.0.0.1:8000/health && vite\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.16",
    "@telnyx/webrtc": "^2.27.1",
    "@vapi-ai/web": "^2.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^3.5.0",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  }
}
