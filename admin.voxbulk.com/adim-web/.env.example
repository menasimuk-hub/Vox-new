# Easiest local start: from this folder run `npm install` then `npm run dev:full`
# (starts FastAPI on 0.0.0.0:8000 from ../../voxbulk-api, then Vite after /health is ready).
#
# Leave VITE_API_BASE_URL unset in local dev so the admin app calls same-origin /auth, /admin, /health
# (Vite proxies to FastAPI — see vite.config.js).
#
# Uncomment only for a remote API or `vite preview` against a non-localhost host:
# VITE_API_BASE_URL=https://admin.voxbulk.com
# VITE_PUBLIC_APP_URL=https://voxbulk.com

# Where the Vite dev server (Node) forwards proxied API routes (not exposed to the browser bundle):
VITE_PROXY_API_TARGET=http://127.0.0.1:8000

# Set to false to stop using the dev proxy and fall back to direct http://127.0.0.1:8000 from the browser:
# VITE_DEV_API_PROXY=false

# If you set VITE_API_BASE_URL to http://127.0.0.1:8000 or http://localhost:8000, dev still uses the proxy
# unless you force true browser cross-origin:
# VITE_FORCE_CROSS_ORIGIN_API=true
