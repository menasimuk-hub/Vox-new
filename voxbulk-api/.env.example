ENV=development
APP_NAME=Retover API

# Security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
# JWT session length (10080 = 7 days). Users must sign in again after deploy to pick up a new token.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Encryption (Fernet, urlsafe_b64 key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=MDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDA=

# Database
# Local default can be SQLite for zero-setup dev:
DATABASE_URL=sqlite:///./retover.local.db
# Example MySQL:
# DATABASE_URL=mysql+pymysql://retover:retover@127.0.0.1:3306/retover
DB_ECHO=false
DB_POOL_PRE_PING=true

# DeepInfra — Whisper STT (WA voice notes) + EU Mistral script moderation (also set in Admin → Integrations → DeepInfra)
DEEPINFRA_API_KEY=

# Inline WhatsApp STT provider order (customer feedback voice notes; default: deepgram,deepinfra,whisper_cpp,groq)
# VOICE_STT_PROVIDER_ORDER=deepinfra,whisper_cpp,groq
# ffmpeg path for web voice transcode (browser webm → ogg before STT)
# FFMPEG_BINARY=ffmpeg

# CORS — leave EMPTY in local dev to allow all default TanStack+Vite origins (5173 public, 5174 admin,
# 5175 dashboard) plus LAN via regex. If you set this, you MUST include every origin you use, e.g.:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
# Production VPS (admin calls https://api.voxbulk.com from the browser):
# CORS_ALLOW_ORIGINS=https://voxbulk.com,https://www.voxbulk.com,https://admin.voxbulk.com,https://dashboard.voxbulk.com
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# Trusted hosts — optional in dev (ENV=development defaults to "*" if unset).
# Production VPS (nginx sends Host: api.voxbulk.com):
# TRUSTED_HOSTS=api.voxbulk.com,localhost,127.0.0.1
TRUSTED_HOSTS=

# ── Production VPS (required — fixes OAuth redirect to localhost:5173) ─────────
# Uncomment and set on /www/voxbulk/voxbulk-api/.env then ./vox.sh restart
# ENV=production
# PUBLIC_APP_ORIGIN=https://voxbulk.com
# DASHBOARD_APP_ORIGIN=https://dashboard.voxbulk.com
# CORS_ALLOW_ORIGINS=https://voxbulk.com,https://www.voxbulk.com,https://admin.voxbulk.com,https://dashboard.voxbulk.com
# TRUSTED_HOSTS=api.voxbulk.com,localhost,127.0.0.1
# Verify: bash scripts/vps-check-auth-env.sh

# Zoom Server-to-Server OAuth — bootstrap only (first-time seed when DB row is empty).
# Prefer Admin → Integrations → Telnyx → Zoom tab or Integrations → Zoom.
# After saving in admin, credentials live in provider_configs (encrypted); .env is not re-read on restart.
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_BASE_URL=https://api.zoom.us/v2

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Webhook signature secrets
# Telnyx messaging inbound webhook: POST /telnyx/webhooks/messages
# Telnyx voice webhooks: /telnyx/webhooks/voice and /telnyx/webhooks/status
# Meta WhatsApp webhook: GET/POST https://api.voxbulk.com/webhooks/meta/whatsapp
VAPI_WEBHOOK_SECRET=change-me
VAPI_API_KEY=change-me
# Telnyx API v2 secret key (KEY…); optional if stored in Admin → Integrations → Telnyx
TELNYX_API_KEY=
# Meta WhatsApp Cloud API — manual ops (scripts/register_whatsapp_number.py)
# Also stored in Admin → Integrations → Meta WhatsApp and connection profiles.
META_PHONE_NUMBER=+447822002099
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WHATSAPP_PIN=
# Optional Graph API version (default v25.0 in script; Meta docs often cite v20.0+)
# META_GRAPH_API_VERSION=v25.0
# WhatsApp survey outbound pacing (seconds between bot messages; 0 = immediate)
WA_SURVEY_STEP_DELAY_SECONDS=2
WA_MESSAGES_PER_SECOND=8
WA_DISPATCH_CHUNK_SIZE=25
WA_DISPATCH_CHUNK_PAUSE_SECONDS=1
WA_SURVEY_BRANCH_DELAY_SECONDS=3.5
# GoCardless: HMAC-SHA256 (hex) of raw body; header Webhook-Signature (see /webhooks/gocardless).
# When creating payments/invoices, set resource metadata: org_id (UUID), client_email, optional amount_gbp_pence.
# Sandbox/live API access token is stored encrypted from Admin > Integrations > GoCardless, not in this file.
GOCARDLESS_WEBHOOK_SECRET=change-me
# Local/test only: allow instant manual package changes without a payment provider.
# In production leave this false unless you intentionally want manual test billing enabled.
# Keep false whenever Stripe/Airwallex is configured — true only credits wallet without card payment.
ENABLE_TEST_CASH_BILLING=false

# Local dev sign-in (auto-created/reset on API startup when ENV=development):
LOCAL_ADMIN_EMAIL=zaghlolno@gmail.com
LOCAL_ADMIN_PASSWORD=testtest1
LOCAL_DASHBOARD_EMAIL=user@user.com
LOCAL_DASHBOARD_PASSWORD=testtest1

# Public app URL for invite/reset links and OAuth callback redirect (sign-in handoff).
# OAuth always redirects to PUBLIC_APP_ORIGIN/signin#access_token=... — MUST NOT be localhost on VPS.
# Dashboard social login (PWA) uses DASHBOARD_APP_ORIGIN/login — REQUIRED on production VPS.
PUBLIC_APP_ORIGIN=http://localhost:5173
DASHBOARD_APP_ORIGIN=http://localhost:5175
# Production VPS (both required for OAuth + installed dashboard app):
# PUBLIC_APP_ORIGIN=https://voxbulk.com
# DASHBOARD_APP_ORIGIN=https://dashboard.voxbulk.com
BOOKING_APP_ORIGIN=

# Invoice PDF header (optional — also editable via invoice_document email template)
INVOICE_COMPANY_NAME=VOXBULK
INVOICE_COMPANY_ADDRESS=VOXBULK Ltd\nLondon, United Kingdom
INVOICE_COMPANY_EMAIL=billing@voxbulk.com
INVOICE_COMPANY_VAT=

# Dentally (sync foundations)
DENTALLY_BASE_URL=https://api.dentally.co
DENTALLY_API_KEY=change-me

# Interview scheduling OAuth (prefer Admin → Integrations → Calendly / Cronofy)
# CALENDLY_CLIENT_ID=
# CALENDLY_CLIENT_SECRET=
# CALENDLY_REDIRECT_URI=https://api.voxbulk.com/service-orders/scheduling/oauth/calendly/callback
# CAL_COM_CLIENT_ID=
# CAL_COM_CLIENT_SECRET=
# CAL_COM_REDIRECT_URI=https://api.voxbulk.com/service-orders/scheduling/oauth/cal-com/callback
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=https://api.voxbulk.com/service-orders/scheduling/oauth/google-calendar/callback
# CRONOFY_* — legacy; no longer used for new org connections
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# HUBSPOT_REDIRECT_URI=https://api.voxbulk.com/service-orders/hubspot/oauth/callback
# Optional kill switch for HubSpot contact sync v1 beta (overrides admin platform flag when set): 0|1
# HUBSPOT_CONTACT_SYNC_V1_ENABLED=

# Interview booking: 4-minute slots, 24 hours/day (no 9:00–17:30 cap). Disable in production.
INTERVIEW_SLOT_MINUTES=4
INTERVIEW_RELAX_HOURS=1

# Email (interview invites, confirm, stop). SMTP in Admin → Email; fallback if SMTP fails:
# RESEND_API_KEY=re_xxxx  (or Resend key in Admin → AI Team integrations)
# SMTP_SSL_INSECURE=1       (only if your mail server uses self-signed TLS)

# Dashboard AI assistant (v1.5 — read-only guide + optional LLM)
# Set true when OPENAI_API_KEY (or DeepSeek/DeepInfra/Groq) is configured — enables LLM classify/synthesize for the dashboard assistant.
# ASSISTANT_LLM_ENABLED=true
# ASSISTANT_LLM_PROVIDER=openai
# openai | deepseek | deepinfra | groq
# ASSISTANT_LLM_PROVIDER=deepinfra
# ASSISTANT_LLM_MODEL=mistralai/Mistral-Small-3.2-24B-Instruct-2506
# ASSISTANT_ERROR_ALERT_THRESHOLD=5
# ASSISTANT_ERROR_ALERT_WINDOW_SEC=300
# ASSISTANT_ONCALL_ADMIN_EMAILS=ops@voxbulk.com
# ASSISTANT_RATE_LIMIT_PER_MIN=20
