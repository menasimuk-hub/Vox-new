ENV=development
APP_NAME=Retover API

# Security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption (Fernet, urlsafe_b64 key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=MDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDA=

# Database
# Local default can be SQLite for zero-setup dev:
DATABASE_URL=sqlite:///./retover.local.db
# Example MySQL:
# DATABASE_URL=mysql+pymysql://retover:retover@127.0.0.1:3306/retover
DB_ECHO=false
DB_POOL_PRE_PING=true

# CORS — leave EMPTY in local dev to allow all default TanStack+Vite origins (5173 public, 5174 admin,
# 5175 dashboard) plus LAN via regex. If you set this, you MUST include every origin you use, e.g.:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# Trusted hosts — optional in dev (ENV=development defaults to "*" if unset).
# Example production: APP_HOST,*.retover.ai
TRUSTED_HOSTS=

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Webhook signature secrets
# Twilio: set to your Twilio Auth Token (required for validating X-Twilio-Signature)
TWILIO_AUTH_TOKEN=change-me
TWILIO_ACCOUNT_SID=change-me
TWILIO_API_KEY=change-me
TWILIO_API_SECRET=change-me
TWILIO_FROM_NUMBER=+447000000000
TWILIO_TWIML_URL=https://example.com/twiml.xml
TWILIO_WHATSAPP_FROM=whatsapp:+447000000000
# Twilio sandbox/test credentials can also be stored encrypted from Admin > Integrations > Twilio.
# WhatsApp sandbox webhook: /twilio/webhooks/whatsapp
# Voice status callback: /twilio/webhooks/calls
VAPI_WEBHOOK_SECRET=change-me
VAPI_API_KEY=change-me
# Telnyx API v2 secret key (KEY…); optional if stored in Admin → Integrations → Telnyx
TELNYX_API_KEY=
# GoCardless: HMAC-SHA256 (hex) of raw body; header Webhook-Signature (see /webhooks/gocardless).
# When creating payments/invoices, set resource metadata: org_id (UUID), client_email, optional amount_gbp_pence.
# Sandbox/live API access token is stored encrypted from Admin > Integrations > GoCardless, not in this file.
GOCARDLESS_WEBHOOK_SECRET=change-me
# Local/test only: allow instant manual package changes without a payment provider.
# In production leave this false unless you intentionally want manual test billing enabled.
ENABLE_TEST_CASH_BILLING=false

# Bootstrap (one-time initial org + admin)
BOOTSTRAP_TOKEN=change-me

# Public app URL for invite/reset links (admin UI shows sign-in URLs)
PUBLIC_APP_ORIGIN=http://localhost:5173
# Dashboard app URL used for billing redirects.
DASHBOARD_APP_ORIGIN=http://localhost:5175

# Dentally (sync foundations)
DENTALLY_BASE_URL=https://api.dentally.co
DENTALLY_API_KEY=change-me
